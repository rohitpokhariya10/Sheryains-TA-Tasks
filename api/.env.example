# ---- App ----
NODE_ENV=development
PORT=8000
CLIENT_URL=http://localhost:5173

# ---- Database ----
MONGO_URI=mongodb://127.0.0.1:27017/chotuapp

# ---- JWT ----
ACCESS_TOKEN_SECRET=replace_with_a_64_plus_character_random_secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=replace_with_a_different_64_plus_character_random_secret
REFRESH_TOKEN_EXPIRY=7d

# ---- Cookies ----
COOKIE_DOMAIN=localhost

# ---- ImageKit ----
IMAGEKIT_PUBLIC_KEY=public_replace_with_your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=private_replace_with_your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/replace_with_your_imagekit_id
